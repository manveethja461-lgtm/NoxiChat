{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the chat system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "email": { "type": "string", "description": "The user's email address." },
        "lastSeen": { "type": "string", "format": "date-time", "description": "When the user was last active." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a conversation between users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user UIDs participating in the chat."
        },
        "lastMessage": { "type": "string", "description": "The content of the last message sent." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the chat was last updated." }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a single message in a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "UID of the user who sent the message." },
        "text": { "type": "string", "description": "The message content." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "type": { "type": "string", "enum": ["text", "image"], "description": "The type of message." }
      },
      "required": ["senderId", "text", "timestamp", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata and participants."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat."
    }
  }
}
